import cv2
import numpy as np

# Путь к видео
video_path = r"C:\Users\26\Desktop\Day1\checklile\for_pub\eval1\robot_2026-03-13_10-27-09.avi"
cap = cv2.VideoCapture(video_path)

# Открываем файл для записи (user.txt)
with open("user.txt", "w") as log_file:
    # Параметры П-регулятора (подберите под логи организаторов)
    BASE_SPEED = 50 
    K_P = 0.3 # Коэффициент поворота

    while cap.isOpened():
        ret, frame = cap.read()
        if not ret:
            break

        # 1. Обработка видео (Детекция черной линии)
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        
        # Инвертируем, чтобы линия была белой на черном фоне (для поиска контуров)
        _, thresh = cv2.threshold(gray, 70, 255, cv2.THRESH_BINARY_INV)

        # Выбираем рабочую область внизу кадра
        h, w = thresh.shape
        roi = thresh[int(h*0.7):int(h*0.9), :]
        
        # Находим центр линии через моменты
        M = cv2.moments(roi)
        
        # Значения по умолчанию (едем прямо)
        v_left, v_right = BASE_SPEED, BASE_SPEED

        if M["m00"] > 0:
            cx = int(M["m10"] / M["m00"])
            
            # Ошибка отклонения от центра кадра
            error = cx - (w // 2)
            
            # 2. Расчет скоростей
            # Если линия справа (error > 0), левый мотор быстрее, правый медленнее
            v_left = int(BASE_SPEED + error * K_P)
            v_right = int(BASE_SPEED - error * K_P)

            # Ограничиваем скорость в разумных пределах (например, 0-100)
            v_left = max(0, min(100, v_left))
            v_right = max(0, min(100, v_right))

            # Визуализация (для 20 баллов)
            cv2.circle(frame, (cx, int(h*0.8)), 7, (0, 0, 255), -1)

        # 3. Сохранение скоростей (ФОРМАТ: "лево право")
        # ВНИМАНИЕ: Если в true.txt числа через запятую, замените пробел ниже на запятую
        log_file.write(f"{v_left} {v_right}\n")

        # Вывод на экран для контроля
        cv2.putText(frame, f"L:{v_left} R:{v_right}", (20, 40), 
                    cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 255, 0), 2)
        cv2.imshow('Line Tracking', frame)

        if cv2.waitKey(1) & 0xFF == ord('q'):
            break
